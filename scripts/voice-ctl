#!/bin/bash
set -euo pipefail

CONTROL_HOST="${KOKORO_CONTROL_HOST:-localhost}"
CONTROL_PORT="${KOKORO_CONTROL_PORT:-18880}"
BASE_URL="http://${CONTROL_HOST}:${CONTROL_PORT}"
TIMEOUT=2

show_help() {
  cat <<EOF
Usage: voice-ctl <command> [args]

Commands:
  speak [TEXT]      Speak text. If no TEXT, reads from clipboard. Use '-' to read from stdin.
  stop              Stop playback and clear queue
  pause             Toggle pause/resume on current playback
  status            Show playback status
  help              Show this help message

Examples:
  voice-ctl speak "Hello, world"
  voice-ctl speak                    # reads from clipboard
  echo "Hello" | voice-ctl speak -   # reads from stdin
  voice-ctl stop
  voice-ctl pause
  voice-ctl status

Environment:
  KOKORO_CONTROL_HOST  Default: localhost
  KOKORO_CONTROL_PORT  Default: 18880

Exit codes:
  0  Success
  1  Error
  2  Server unreachable
EOF
}

check_server() {
  if ! curl -s --max-time "$TIMEOUT" "${BASE_URL}/status" >/dev/null 2>&1; then
    echo "Error: Kokoro control server unreachable at ${BASE_URL}" >&2
    return 2
  fi
  return 0
}

cmd_speak() {
  if ! check_server; then
    return 2
  fi

  local text
  if [ $# -eq 0 ]; then
    # Read from clipboard
    text=$(pbpaste)
  elif [ "$1" = "-" ]; then
    # Read from stdin
    text=$(cat)
  else
    # Use argument
    text="$1"
  fi

  if [ -z "$text" ]; then
    echo "Error: no text to speak" >&2
    return 1
  fi

  local response
  response=$(curl -s --max-time "$TIMEOUT" -X POST \
    -d "$text" \
    "${BASE_URL}/speak" 2>&1)

  if [ $? -ne 0 ]; then
    echo "Error: failed to send speak request" >&2
    return 1
  fi

  return 0
}

cmd_stop() {
  if ! check_server; then
    return 2
  fi

  local response
  response=$(curl -s --max-time "$TIMEOUT" -X POST "${BASE_URL}/stop" 2>&1)

  if [ $? -ne 0 ]; then
    echo "Error: failed to send stop request" >&2
    return 1
  fi

  return 0
}

cmd_pause() {
  if ! check_server; then
    return 2
  fi

  local response
  response=$(curl -s --max-time "$TIMEOUT" -X POST "${BASE_URL}/pause" 2>&1)

  if [ $? -ne 0 ]; then
    echo "Error: failed to send pause request" >&2
    return 1
  fi

  return 0
}

cmd_status() {
  if ! check_server; then
    return 2
  fi

  local response
  response=$(curl -s --max-time "$TIMEOUT" "${BASE_URL}/status" 2>&1)

  if [ $? -ne 0 ]; then
    echo "Error: failed to get status" >&2
    return 1
  fi

  # Pretty-print JSON if jq is available, otherwise just output as-is
  if command -v jq &>/dev/null; then
    echo "$response" | jq '.'
  else
    echo "$response"
  fi

  return 0
}

main() {
  if [ $# -eq 0 ]; then
    show_help
    return 0
  fi

  local cmd="$1"
  shift || true

  case "$cmd" in
    speak)
      cmd_speak "$@"
      ;;
    stop)
      cmd_stop "$@"
      ;;
    pause)
      cmd_pause "$@"
      ;;
    status)
      cmd_status "$@"
      ;;
    help|--help|-h)
      show_help
      return 0
      ;;
    *)
      echo "Error: unknown command '$cmd'" >&2
      show_help
      return 1
      ;;
  esac
}

main "$@"
